<?xml version="1.0" encoding="utf-8"?>
<!-- So'zona — Launch theme -->
<resources>
    <!-- Launch theme — ilova yuklanayotganda ko'rinadi -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:statusBarColor">#060414</item>
        <item name="android:navigationBarColor">#060414</item>
    </style>

    <!-- Normal theme — Flutter engine ishga tushgandan keyin -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">#00000000</item>
    </style>
</resources>