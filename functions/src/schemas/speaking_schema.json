{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "topic",
        "level",
        "language",
        "turns",
        "vocabulary"
    ],
    "properties": {
        "topic": {
            "type": "string",
            "minLength": 1
        },
        "level": {
            "type": "string",
            "enum": [
                "beginner",
                "intermediate",
                "advanced"
            ]
        },
        "language": {
            "type": "string",
            "enum": [
                "english",
                "deutsch"
            ]
        },
        "turns": {
            "type": "array",
            "minItems": 4,
            "items": {
                "type": "object",
                "required": [
                    "speaker"
                ],
                "properties": {
                    "speaker": {
                        "type": "string",
                        "enum": [
                            "student",
                            "partner"
                        ]
                    },
                    "text": {
                        "type": "string"
                    },
                    "translation": {
                        "type": "string"
                    },
                    "tips": {
                        "type": "string"
                    },
                    "suggestion": {
                        "type": "string"
                    },
                    "alternatives": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "vocabulary": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "word",
                    "translation"
                ],
                "properties": {
                    "word": {
                        "type": "string"
                    },
                    "translation": {
                        "type": "string"
                    },
                    "example": {
                        "type": "string"
                    }
                }
            }
        },
        "culturalNotes": {
            "type": "string"
        }
    }
}