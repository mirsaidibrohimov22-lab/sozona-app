{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "topic",
        "explanation",
        "examples",
        "tips"
    ],
    "properties": {
        "topic": {
            "type": "string",
            "minLength": 1
        },
        "explanation": {
            "type": "string",
            "minLength": 10
        },
        "examples": {
            "type": "array",
            "minItems": 2,
            "items": {
                "type": "object",
                "required": [
                    "sentence",
                    "translation"
                ],
                "properties": {
                    "sentence": {
                        "type": "string"
                    },
                    "translation": {
                        "type": "string"
                    },
                    "note": {
                        "type": "string"
                    }
                }
            }
        },
        "commonMistakes": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "wrong",
                    "correct",
                    "why"
                ],
                "properties": {
                    "wrong": {
                        "type": "string"
                    },
                    "correct": {
                        "type": "string"
                    },
                    "why": {
                        "type": "string"
                    }
                }
            }
        },
        "tips": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "string"
            }
        },
        "relatedTopics": {
            "type": "array",
            "items": {
                "type": "string"
            }
        }
    }
}