{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Listening Exercise Schema",
    "description": "AI tomonidan yaratilgan listening mashqi uchun JSON schema",
    "type": "object",
    "required": [
        "transcript",
        "questions"
    ],
    "properties": {
        "transcript": {
            "type": "string",
            "minLength": 50,
            "maxLength": 5000,
            "description": "Audio transkripsiya (target tilda) - minimal 50 belgi"
        },
        "questions": {
            "type": "array",
            "minItems": 1,
            "maxItems": 20,
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "timestamp",
                    "type",
                    "question",
                    "options",
                    "correctAnswer",
                    "explanation"
                ],
                "properties": {
                    "id": {
                        "type": "string",
                        "pattern": "^lq[0-9]+$",
                        "description": "Savol ID - 'lq1', 'lq2', ..."
                    },
                    "timestamp": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 600,
                        "description": "Javob audio'da qayerda joylashgan (soniyalarda)"
                    },
                    "type": {
                        "type": "string",
                        "enum": [
                            "mcq",
                            "true_false"
                        ],
                        "description": "Savol turi: MCQ yoki True/False"
                    },
                    "question": {
                        "type": "string",
                        "minLength": 5,
                        "maxLength": 500,
                        "description": "Savol matni (target tilda)"
                    },
                    "options": {
                        "type": "array",
                        "minItems": 2,
                        "maxItems": 4,
                        "items": {
                            "type": "string",
                            "minLength": 1,
                            "maxLength": 200
                        },
                        "description": "Javob variantlari"
                    },
                    "correctAnswer": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 200,
                        "description": "To'g'ri javob (options'dan birini to'liq ko'chirish kerak)"
                    },
                    "explanation": {
                        "type": "string",
                        "minLength": 10,
                        "maxLength": 1000,
                        "description": "Javob tushuntirilishi (target tilda)"
                    }
                }
            }
        }
    }
}