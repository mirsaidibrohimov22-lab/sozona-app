{
    "name": "sozona-cloud-functions",
    "version": "1.0.0",
    "description": "SO'ZONA Cloud Functions - AI Proxy for OpenAI/Gemini",
    "main": "lib/index.js",
    "scripts": {
        "build": "tsc",
        "serve": "npm run build && firebase emulators:start --only functions",
        "shell": "npm run build && firebase functions:shell",
        "start": "npm run shell",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log",
        "test": "jest --passWithNoTests"
    },
    "engines": {
        "node": "22"
    },
    "dependencies": {
        "@google/generative-ai": "^0.1.3",
        "ajv": "^8.12.0",
        "axios": "^1.6.0",
        "firebase-admin": "^12.7.0",
        "firebase-functions": "^4.9.0",
        "openai": "^4.104.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "@types/node": "^22.0.0",
        "firebase-functions-test": "^3.1.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "testMatch": [
            "**/test/**/*.test.ts"
        ]
    },
    "private": true,
    "directories": {
        "test": "test"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs"
}
